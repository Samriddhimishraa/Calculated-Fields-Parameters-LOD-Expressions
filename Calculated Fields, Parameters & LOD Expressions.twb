      <aliases enabled='yes' />
      <column caption='Delivery Status ' datatype='string' name='[Calculation_0195355394527232]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Delivery_Time_Min] &lt;= 30 THEN &quot;Fast&quot;&#10;ELSE &quot;Delayed&quot;&#10;END' />
      </column>
      <column caption='Loss Flag' datatype='string' name='[Calculation_0195355395260417]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Profit] &lt; 0 THEN &quot;Loss&quot;&#10;ELSE &quot;Profit&quot;&#10;END' />
      </column>
      <column caption='Product Rank' datatype='integer' name='[Calculation_0195355396583426]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(SUM([Sales]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Top N Filter' datatype='boolean' name='[Calculation_0195355396710403]' role='measure' type='nominal'>
        <calculation class='tableau' formula='RANK(SUM([Sales])) &lt;= [Parameters].[Parameter 1]'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='City Avg Sales' datatype='real' name='[Calculation_0195355400286214]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [City] : AVG([Sales]) }' />
      </column>
      <column caption='Product Avg Sales' datatype='real' name='[Calculation_0195355400658951]' role='measure' type='quantitative'>
